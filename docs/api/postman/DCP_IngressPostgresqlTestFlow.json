	"item": [
		{
			"name": "IdH Automatic Issuance Flow",
			"item": [
				{
					"name": "Set Up Participant Context",
					"item": [
						{
							"name": "Set Admin Api Key",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"exec": [
											"// Set ADMIN API KEY AND PARTICIPANT CONTEXT",
											"// These are read from the collection variables IDH_API_KEY_ADMIN and ISSUER_API_KEY_ADMIN.",
											"// Fill them in with the super-user API keys from the startup logs.",
											"",
											"var identityApiKey = pm.collectionVariables.get(\"IDH_API_KEY_ADMIN\");",
											"var issuerserviceApiKey = pm.collectionVariables.get(\"ISSUER_API_KEY_ADMIN\");",
											"",
											"if (!identityApiKey || !issuerserviceApiKey) {",
											"    throw new Error('Please set IDH_API_KEY_ADMIN and ISSUER_API_KEY_ADMIN collection variables before running.');",
											"}",
											"",
											"pm.collectionVariables.set(\"ISSUER_PARTICIPANT_CONTEXT_ADMIN\", issuerserviceApiKey.split(\".\")[0]);",
											"pm.collectionVariables.set(\"IDH_PARTICIPANT_CONTEXT_ADMIN\", identityApiKey.split(\".\")[0]);"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://postman-echo.com/get",
									"protocol": "https",
									"host": [
										"postman-echo",
										"com"
									],
									"path": [
										"get"
									]
								}
							},
							"response": []
						},
						{
							"name": "IssuerService Create ParticipantContext",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test(\"Status code is 200\", function () {",
											"    pm.response.to.have.status(200);",
											"",
											"    var json = pm.response.json();",
											"    console.log(json);",
											"",
											"    pm.collectionVariables.set(\"ISSUER_API_KEY\", json.apiKey);",
											"    pm.collectionVariables.set(\"ISSUER_PARTICIPANT_CONTEXT\", json.apiKey.split(\".\")[0]);",
											"});"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
							],
							"request": {
								"auth": {
									"type": "apikey",
									"apikey": [
										{
											"key": "value",
											"value": "{{ISSUER_API_KEY_ADMIN}}",
											"type": "string"
										},
										{
											"key": "key",
											"value": "x-api-key",
											"type": "string"
										}
									]
								},
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"active\": true,\n  \"did\": \"did:web:issuer-service.int.catena-x.net\",\n  \"key\": {\n    \"keyGeneratorParams\": {\n      \"algorithm\": \"Ec\",\n      \"curve\": \"secp256r1\"\n    },\n    \"keyId\": \"did:web:issuer-service.int.catena-x.net#key-1\",\n    \"type\": \"JsonWebKey2020\",\n    \"privateKeyAlias\": \"did:web:issuer-service.int.catena-x.net-privatekey-alias\"\n  },\n  \"participantId\": \"issuer-participant\",\n  \"roles\": [\n    \"ROLE_ADMIN\", \"admin\"\n  ],\n  \"serviceEndpoints\": [\n    {\n      \"id\": \"https://issuer-service.int.catena-x.net#credential-service\",\n      \"type\": \"IssuerService\",\n      \"serviceEndpoint\": \"https://issuer-service.int.catena-x.net/api/issuance/v1alpha/participants/aXNzdWVyLXBhcnRpY2lwYW50\"\n    }\n  ],\n  \"apiKeyAlias\": \"apiKeyAliasTest\"\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{ISSUERSERVICE_INTERNAL_URL}}{{IDENTITY_API}}/v1alpha/participants",
									"host": [
										"{{ISSUERSERVICE_INTERNAL_URL}}{{IDENTITY_API}}"
									],
									"path": [
										"v1alpha",
										"participants"
									]
								}
							},
							"response": []
						},
