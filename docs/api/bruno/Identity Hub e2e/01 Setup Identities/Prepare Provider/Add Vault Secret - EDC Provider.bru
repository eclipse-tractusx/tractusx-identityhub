meta {
  name: Add Vault Secret - EDC Provider
  type: http
  seq: 7
}

post {
  url: {{PROVIDER_EDC_VAULT}}/v1/secret/data/providersecret
  body: json
  auth: inherit
}

headers {
  X-Vault-Token: {{VAULT_TOKEN}}
}

body:json {
  {
    "data": {
      "content": "{{PROVIDER_STS_SECRET}}"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
